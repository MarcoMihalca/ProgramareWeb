<!DOCTYPE html>
<html>
<head>
    <title>Panou Control SmartBag</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: #f4f4f4; font-family: sans-serif; padding: 20px;">
    
    <header>
        <h1>Salut, <%= user.name %>!</h1> <p>Vizite in aceasta sesiune: <strong><%= vizite %></strong></p> <% if (ultima) { %>
            <p>Ultima vizita la ora: <%= ultima %></p> <% } %>

        <a href="/logout">Deconectare (Logout)</a> </header>

    <hr>

    <h3>Comenzi Active SmartBag</h3>
    <table border="1" width="100%" style="background-color: white;">
        <tr style="background-color: #ffcc00;">
            <th>ID Comanda</th>
            <th>Produs</th>
            <th>Temperatura</th>
            <th>Status Senzor</th>
            <th>Actiuni</th>
        </tr>
        <% comenzi.forEach(comanda => { %>
            <tr>
                <td><%= comanda.id %></td>
                <td><%= comanda.produs %></td>
                <td><%= comanda.temperatura %></td>
                <td><%= comanda.senzor_activ %></td>
                <td><a href="/comanda/<%= comanda.id %>">Detalii Live</a></td> </tr>
        <% }) %>
    </table>

</body>
</html>