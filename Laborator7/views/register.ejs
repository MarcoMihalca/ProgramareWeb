<!DOCTYPE html>
<html>
<head>
    <title>Inregistrare SmartBag</title>
</head>
<body style="font-family: sans-serif; text-align: center;">
    <h2>Creeaza un cont SmartBag</h2>
    <form action="/register" method="POST">
        <input type="text" name="nume" placeholder="Nume complet" required><br><br>
        <input type="email" name="email" placeholder="Email" required><br><br>
        <input type="password" name="parola" placeholder="Parola" required><br><br>
        <button type="submit">Inregistrare</button>
    </form>
    <p>Ai deja cont? <a href="/login">Logheaza-te aici</a></p>
</body>
</html>